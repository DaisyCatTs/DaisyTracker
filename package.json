{
  "name": "daisytracker",
  "version": "2.0.2",
  "description": "A minimal GitHub Action that sends polished GitHub push summaries to Discord.",
  "main": "dist/index.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js --legal-comments=none",
    "check": "bun run languages:check && bun run format:check && bun run lint && bun run typecheck && bun test --coverage && bun run build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "languages:check": "bun scripts/update-language-data.ts --check",
    "languages:generate": "bun scripts/update-language-data.ts",
    "lint": "biome lint .",
    "preview": "bun src/cli.ts",
    "test": "bun test",
    "audit": "bun audit --audit-level=high",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-action",
    "discord",
    "webhook",
    "notifications",
    "ci"
  ],
  "author": "DaisyCat",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaisyCatTs/DaisyTracker.git"
  },
  "bugs": {
    "url": "https://github.com/DaisyCatTs/DaisyTracker/issues"
  },
  "homepage": "https://github.com/DaisyCatTs/DaisyTracker#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "bun-types": "^1.3.14",
    "discord-api-types": "^0.38.48",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
